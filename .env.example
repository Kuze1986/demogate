## Core app
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

## Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

## AI routing / chat
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

## Email follow-up
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@your-domain.com

## Admin / governance
ADMIN_EMAIL=founder@your-domain.com
ADMIN_CRON_SECRET=replace-with-strong-secret
SSO_DOMAIN_TENANT_SLUGS=

## Payments (optional; required for billing pages/routes)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SUBSCRIPTION_PRO=
STRIPE_PRICE_ONE_TIME_CREDITS=

## CRM integrations (optional)
HUBSPOT_PRIVATE_APP_TOKEN=
SALESFORCE_INSTANCE_URL=

## Video pipeline / queue (optional)
REDIS_URL=
VIDEO_WORKER_CONCURRENCY=2
VIDEO_SKIP_EXPENSIVE_VARIANTS=false
DEMOFORGE_VIDEO_UPLOAD=true
DEMOFORGE_MEDIA_RETENTION_DAYS=30
DEMOFORGE_VIDEO_BUCKET=demo-videos
DEMOFORGE_MEDIA_CDN_BASE_URL=
ORCHESTRATOR_WEBHOOK_URL=

## Crucible simulator (optional)
CRUCIBLE_SIM_BASE_URL=
CRUCIBLE_SIM_API_KEY=
CRUCIBLE_SIM_PROFILE_PATH=/api/behavior/profile
